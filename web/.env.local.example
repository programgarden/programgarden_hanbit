# HANBIT web — environment template. Copy to .env.local and adjust.
# 프런트엔드는 값이 없거나 백엔드에 못 닿아도 폴백 데이터로 기동됩니다.

# 브라우저에서 직접 호출할 REST/WS 베이스. 기본은 same-origin 프록시(/api/v1)라 보통 불필요.
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# Next.js 서버(rewrites·SSR)가 프록시할 백엔드 origin. 컨테이너/원격 포트 매핑과 무관하게 동작.
BACKEND_ORIGIN=http://localhost:8000
